# Environment Variables for Heal Home Net Backend

# Database
DATABASE_URL="mongodb+srv://username:password@cluster.mongodb.net/heal-home-net?retryWrites=true&w=majority"

# Server Configuration
PORT=5000
ENV=development

# JWT Secret
JWT_SECRET=your_super_secret_jwt_key_change_this_in_production

# JWT Expiration (in hours)
JWT_EXPIRATION=24

# CORS Configuration
CORS_ORIGIN=http://localhost:5173,http://localhost:8080,http://localhost:3000

# API Keys (if needed for external services)
TWILIO_ACCOUNT_SID=your_twilio_account_sid
TWILIO_AUTH_TOKEN=your_twilio_auth_token
TWILIO_PHONE_NUMBER=+1234567890

# Email Configuration (for notifications)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your_email@gmail.com
SMTP_PASS=your_email_password

# Payment Gateway (Optional - for UPI/Razorpay)
RAZORPAY_KEY_ID=your_razorpay_key_id
RAZORPAY_KEY_SECRET=your_razorpay_key_secret

# File Upload
MAX_FILE_SIZE=5242880
UPLOAD_DIR=./uploads
